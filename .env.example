# JWT 설정
# 중요: JWT_SECRET은 반드시 안전한 랜덤 문자열로 변경하세요!
JWT_SECRET=
JWT_EXPIRE=24h

# 서버 설정
PORT=3000

# AI 서버 설정
FLASK_AI_SERVICE_URL=http://localhost:5001
FLASK_API_TIMEOUT=30000  # 30초

# ── GitHub ─────────────────────────────────────────────────────
# Colab에서 private repo clone/pull 시 사용
GITHUB_TOKEN=

# ── Google Drive ───────────────────────────────────────────────
# 루트 폴더 ID (URL에서 확인)
SKINAI_DRIVE_FOLDER_ID=

# manifest.csv 파일 ID (build_manifest.py 실행 후 채움)
MANIFEST_FILE_ID=